{
  "name": "@gwdn/nexus-mcp",
  "version": "0.9.0",
  "description": "MCP server for the Gatewarden Nexus platform — mediation layer between local agent runtimes and the Nexus HTTP API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "nexus-mcp": "dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gwnexus/nexus-mcp.git"
  },
  "homepage": "https://nexus.gatewarden.eu",
  "bugs": {
    "url": "https://github.com/gwnexus/nexus-mcp/issues"
  },
  "author": "RelicFrog Holding UG (haftungsbeschraenkt)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nexus",
    "ai-agent",
    "agent-coordination",
    "knowledge-management"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  }
}
