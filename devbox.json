{
  "env": {
    "NODE_ENV": "development",
    "HEADROOM_MODE": "transform",
    "HEADROOM_DEBUG": "false",
    "NEXT_TELEMETRY_DISABLED": "1",
    "HEADROOM_REQUIRE_PREFLIGHT": "true",
    "POWERLEVEL9K_INSTANT_PROMPT": "quiet",
    "HEADROOM_RETRIEVAL_MAX_CHARS": "24000",
    "HEADROOM_RETRIEVAL_MAX_LINES": "200",
    "HEADROOM_ALLOW_FULL_RETRIEVAL": "false",
    "C_DBX_META_TEAM": "NEXUS-Labs",
    "C_DBX_META_TEAM_ID": "NEXUS-Labs-DD",
    "C_DBX_META_PROJECT_ID": "NEXUS-MCP",
    "C_DBX_META_TEAM_DESCRIPTION": "Nexus SaaS Development Team"
  },
  "shell": {
    "scripts": {
      "dev": [
        "npm run dev"
      ],
      "test": [
        "npm test"
      ],
      "build": [
        "npm run build"
      ],
      "tmux-2w": [
        "bash scripts/devbox/dbx_tmux_2w.sh"
      ],
      "tmux-3w": [
        "bash scripts/devbox/dbx_tmux_3w.sh"
      ],
      "sec-scan": [
        "bash scripts/devbox/ops/sec-scan.sh"
      ],
      "validate": [
        "bash scripts/devbox/ops/validate.sh"
      ],
      "typecheck": [
        "npm run typecheck"
      ],
      "check-local": [
        "bash scripts/devbox/ops/check-local.sh"
      ]
    },
    "init_hook": [
      "scripts/devbox/dbx_init.sh"
    ]
  },
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": {
    "fd": "latest",
    "jq": "latest",
    "bat": "0.24.0",
    "fzf": "0.54.0",
    "git": "latest",
    "glow": "1.5.1",
    "tmux": "3.4",
    "tmuxp": "1.47.0",
    "lazygit": "0.43.1",
    "ripgrep": "14.1.0",
    "gitleaks": "latest",
    "git-cliff": "latest",
    "nodejs_22": "latest",
    "commitizen": "3.29.1",
    "pre-commit": "3.7.1"
  }
}